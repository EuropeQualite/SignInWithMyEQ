# ── MyEQ OpenID Connect configuration ────────────────────────────────────────
# Copy this file to `.env` and fill in the values for your registered client.
# All variables are prefixed with VITE_ so Vite exposes them to the browser.

# Issuer (authority). The app discovers every endpoint from
# `<authority>/.well-known/openid-configuration`.
#   Production: https://auth.europequalitegroup.com
#   Staging:    https://beta.auth.europequalitegroup.com
VITE_OIDC_AUTHORITY=https://auth.europequalitegroup.com

# The client_id of the PUBLIC client you registered in MyEQ
# (Internal portal → System → OAuth Clients → "public client").
VITE_OIDC_CLIENT_ID=my-demo-rp

# Must EXACTLY match one of the client's registered redirect URIs.
# Defaults to <origin>/callback.html when left empty.
VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback.html

# Space-separated scopes. `openid` is mandatory. Add `offline_access` to receive
# a refresh token, `erp:employee` to receive the ERP employee claim set.
VITE_OIDC_SCOPE=openid profile email
